    "pm25": {"warning": ">=15/15m", "critical": ">=35/10m", "recovery": "<10/15m"},
    "battery": {"warning": "<=20%/30m", "critical": "<=10%/15m", "recovery": ">=25%/30m"},
    "filter_life": {"warning": "<=10%/1h", "critical": "<=2%/1h", "recovery": ">=15%/1h"},
    "source": {"warning": "unavailable/5m", "critical": "unavailable/30m", "recovery": "current/5m"},
